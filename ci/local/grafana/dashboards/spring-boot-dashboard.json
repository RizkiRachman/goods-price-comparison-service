{
  "dashboard": {
    "id": null,
    "title": "Goods Price Service - Spring Boot Metrics",
    "tags": ["spring-boot", "jvm", "micrometer"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count[5m])",
            "legendFormat": "{{method}} {{uri}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "datasource": "Prometheus"
      },
      {
        "id": 2,
        "title": "Average Response Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum[5m]) / rate(http_server_requests_seconds_count[5m])",
            "legendFormat": "{{method}} {{uri}}",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "datasource": "Prometheus"
      },
      {
        "id": 3,
        "title": "JVM Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'}",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.7},
                {"color": "red", "value": 0.9}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "datasource": "Prometheus"
      },
      {
        "id": 4,
        "title": "JVM Threads",
        "type": "stat",
        "targets": [
          {
            "expr": "jvm_threads_live_threads",
            "refId": "D"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "datasource": "Prometheus"
      },
      {
        "id": 5,
        "title": "GC Pause Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum[5m])",
            "refId": "E"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "datasource": "Prometheus"
      },
      {
        "id": 6,
        "title": "HTTP 4xx/5xx Errors",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{status=~'4..|5..'}[5m])",
            "legendFormat": "{{status}}",
            "refId": "F"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
        "datasource": "Prometheus"
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
  },
  "overwrite": false
}
